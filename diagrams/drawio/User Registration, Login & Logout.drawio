<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="NLECVG1ZdSXnl-9wtujW">
    <mxGraphModel dx="1053" dy="594" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Registration &amp; Login\ntitle Sequence Diagram - User Registration, Login &amp; Logout\n\nactor Customer\nactor Provider as \&quot;Provider\&quot;\nparticipant System\ndatabase Database\n\n== Customer Registration ==\n\nCustomer -&gt; System : Navigate to Register Page\nSystem --&gt; Customer : Display Registration Form\n\nCustomer -&gt; System : Submit Registration\\n(name, email, phone, address,\\npassword, user_type=customer)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Check Email Uniqueness\nDatabase --&gt; System : Email Available\n\nSystem -&gt; Database : Create User Record\\n(password hashed, email_verified_at=null)\nDatabase --&gt; System : User Created\n\nSystem -&gt; System : Send Verification Email\nSystem -&gt; Database : Notify All Admins\\n(\&quot;New Customer Registered\&quot;)\nSystem --&gt; Customer : Redirect to Email Verification Page\n\nCustomer -&gt; System : Click Verification Link in Email\nSystem -&gt; Database : Set email_verified_at = now()\nDatabase --&gt; System : Email Verified\nSystem --&gt; Customer : Redirect to Customer Dashboard\n\n== Provider Registration ==\n\nProvider -&gt; System : Navigate to Register Page\nSystem --&gt; Provider : Display Registration Form\n\nProvider -&gt; System : Submit Registration\\n(name, email, phone, address,\\npassword, user_type=provider)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Check Email Uniqueness\nDatabase --&gt; System : Email Available\n\nSystem -&gt; Database : Create User Record\\n(password hashed, email_verified_at=null)\nDatabase --&gt; System : User Created\n\nSystem -&gt; System : Send Verification Email\nSystem --&gt; Provider : Redirect to Email Verification Page\n\nProvider -&gt; System : Click Verification Link in Email\nSystem -&gt; Database : Set email_verified_at = now()\nDatabase --&gt; System : Email Verified\nSystem --&gt; Provider : Redirect to Provider Dashboard\n\nnote right of System\n  Provider middleware checks\n  if provider record exists\nend note\n\nSystem --&gt; Provider : Redirect to Onboarding Page\n\nProvider -&gt; System : Submit Company Details\\n(company_name, logo, BRN,\\ncontact, address, description)\nSystem -&gt; Database : Create Provider Record\\n(status = pending)\nDatabase --&gt; System : Provider Created\nSystem --&gt; Provider : Redirect to Pending Approval Page\n\nProvider -&gt; System : Access Dashboard\nSystem -&gt; System : Check Provider Status\nSystem --&gt; Provider : Display \&quot;Awaiting Admin Approval\&quot;\n\n== Login (All User Types) ==\n\nCustomer -&gt; System : Navigate to Login Page\nSystem --&gt; Customer : Display Login Form\n\nCustomer -&gt; System : Submit Credentials\\n(email, password)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Verify Credentials\nDatabase --&gt; System : Authentication Success\n\nalt Email Not Verified\n  System --&gt; Customer : Redirect to Email Verification Page\nelse Email Verified\n  System -&gt; System : Check user_type\n\n  alt user_type = customer\n    System --&gt; Customer : Redirect to Customer Dashboard\n  else user_type = provider\n    System --&gt; Customer : Redirect to Provider Dashboard\n  else user_type = admin\n    System --&gt; Customer : Redirect to Admin Dashboard\n  else user_type = driver\n    System --&gt; Customer : Redirect to Driver Dashboard\n  end\nend\n\n== Login Failed ==\n\nCustomer -&gt; System : Submit Wrong Credentials\\n(email, password)\nSystem -&gt; Database : Verify Credentials\nDatabase --&gt; System : Authentication Failed\nSystem --&gt; Customer : Display Error Message\\n(\&quot;Invalid credentials\&quot;)\n\n== Logout ==\n\nCustomer -&gt; System : Click Logout\nSystem -&gt; System : Flush Session &amp;\\nInvalidate Token\nSystem --&gt; Customer : Redirect to Home Page\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="HGXQpFVhLW0EeE_4AKBs-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2449" width="718" x="30" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
