<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="QrI6C2WLGHl3Ylk1tLAe">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Booking Cancellation\ntitle Sequence Diagram - Booking Cancellation Flow\n\nactor Customer\nactor Admin\nactor Provider as \&quot;Provider\&quot;\nparticipant System\ndatabase Database\n\n== Customer Cancels Own Booking ==\n\nCustomer -&gt; System : Navigate to My Bookings\nSystem -&gt; Database : Fetch Customer&#39;s Bookings\nDatabase --&gt; System : Return Bookings\nSystem --&gt; Customer : Display Booking List\n\nCustomer -&gt; System : Click \&quot;Cancel Booking\&quot;\nSystem -&gt; System : Check booking_status = pending\\nCheck payment != paid\\nCheck departure not passed\n\nalt Validation Fails\n  System --&gt; Customer : Display Error\\n(\&quot;Cannot cancel this booking\&quot;)\nelse Validation Passes\n  System -&gt; Database : Update booking_status\\n= cancelled\n  System -&gt; Database : Restore available_seats\\n(+= total_passengers)\n  Database --&gt; System : Updated\n\n  System -&gt; Database : Notify Customer\\n(\&quot;Booking #BK... cancelled\&quot;)\n  System -&gt; Database : Notify Provider\\n(\&quot;Booking #BK... cancelled\&quot;)\n  Database --&gt; System : Notifications Created\n\n  System --&gt; Customer : Display Success\\n(\&quot;Booking cancelled successfully\&quot;)\nend\n\n== Admin Cancels Any Booking ==\n\nAdmin -&gt; System : Navigate to Booking Management\nSystem -&gt; Database : Fetch All Bookings\nDatabase --&gt; System : Return Bookings\nSystem --&gt; Admin : Display Booking List\n\nAdmin -&gt; System : View Booking and Click Cancel\nSystem -&gt; Database : Update booking_status\\n= cancelled\nSystem -&gt; Database : Restore available_seats\\n(+= total_passengers)\nDatabase --&gt; System : Updated\n\nSystem -&gt; Database : Notify Customer\\n(\&quot;Booking cancelled by admin\&quot;)\nSystem -&gt; Database : Notify Provider\\n(\&quot;Booking cancelled by admin\&quot;)\nDatabase --&gt; System : Notifications Created\n\nSystem --&gt; Admin : Display Success\n\n== Provider Requests Cancellation ==\n\nProvider -&gt; System : View Schedule with\\nActive Bookings\nSystem --&gt; Provider : Display Schedule\\n(modify/delete blocked)\n\nProvider -&gt; System : Click \&quot;Request Cancellation\&quot;\nSystem -&gt; Database : Count Active Bookings\\non Future Dates\nDatabase --&gt; System : Return Count\n\nSystem -&gt; Database : Notify All Admins\\n(\&quot;Provider requests cancellation\\nof N bookings\&quot;)\nDatabase --&gt; System : Notifications Created\nSystem --&gt; Provider : Display Success\\n(\&quot;Request sent to admin\&quot;)\n\nnote right of System\n  Admin then manually cancels\n  each booking from admin panel\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Xz0WakyIEqTAkXe3OGXs-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1653" width="670" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
