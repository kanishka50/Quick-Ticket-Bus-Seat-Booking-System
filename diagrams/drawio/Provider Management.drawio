<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="bAxbw_NmUutMifx05zUc">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Provider Management\ntitle Sequence Diagram - Provider Management\n\nactor Provider\nparticipant System\ndatabase Database\n\n== Add Bus ==\n\nProvider -&gt; System : Navigate to Add Bus\nSystem -&gt; Database : Fetch Bus Types\nDatabase --&gt; System : Return Bus Types\nSystem --&gt; Provider : Display Bus Form\n\nProvider -&gt; System : Submit Bus Details\\n(bus_type, reg_number, name,\\nseat_layout, amenities, status)\nSystem -&gt; System : Validate Input\nSystem -&gt; System : Calculate total_seats\\nfrom seat_layout JSON\nSystem -&gt; Database : Save Bus Record\nDatabase --&gt; System : Bus Created\nSystem --&gt; Provider : Redirect to Bus List\n\n== Create Schedule ==\n\nProvider -&gt; System : Navigate to Create Schedule\nSystem -&gt; Database : Fetch Provider&#39;s Active Buses\nSystem -&gt; Database : Fetch Active Routes\nDatabase --&gt; System : Return Buses and Routes\nSystem --&gt; Provider : Display Schedule Form\n\nProvider -&gt; System : Submit Schedule Details\\n(route, bus, departure_time,\\narrival_time, price, status)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Save Schedule\nDatabase --&gt; System : Schedule Created\nSystem --&gt; Provider : Redirect to Schedule List\n\n== Add Schedule Dates ==\n\nProvider -&gt; System : Navigate to Schedule Dates\nSystem -&gt; Database : Fetch Provider&#39;s Schedules\nDatabase --&gt; System : Return Schedules\nSystem --&gt; Provider : Display Date Picker\n\nProvider -&gt; System : Select Dates for Schedule\nSystem -&gt; System : Validate Dates (&gt;= today)\nSystem -&gt; Database : Check Duplicate Dates\nSystem -&gt; Database : Get Bus Seat Count\\nfrom seat_layout\nloop For Each Date\n  System -&gt; Database : Create ScheduleDate\\n(available_seats = total_seats,\\nstatus = scheduled)\nend\nDatabase --&gt; System : Dates Created\nSystem --&gt; Provider : Display Success\n\n== Assign Driver ==\n\nProvider -&gt; System : Navigate to Driver Assignments\nSystem -&gt; Database : Fetch Provider&#39;s Active Drivers\nSystem -&gt; Database : Fetch Provider&#39;s Schedules\nDatabase --&gt; System : Return Drivers and Schedules\nSystem --&gt; Provider : Display Assignment Form\n\nProvider -&gt; System : Select Driver and Schedule Date\nSystem -&gt; System : Validate\\n(date is future, unassigned)\nSystem -&gt; Database : Create DriverAssignment\\n(status = assigned)\nDatabase --&gt; System : Assignment Created\n\nSystem -&gt; Database : Notify Driver\\n(\&quot;New Trip Assigned\&quot;)\nDatabase --&gt; System : Notification Created\n\nSystem --&gt; Provider : Redirect to Assignment List\n\n== Request Booking Cancellation ==\n\nProvider -&gt; System : View Schedule with\\nActive Bookings\nSystem --&gt; Provider : Display Schedule\\n(cannot modify/delete)\n\nProvider -&gt; System : Click \&quot;Request Cancellation\&quot;\nSystem -&gt; Database : Count Active Bookings\\non Future Dates\nDatabase --&gt; System : Return Booking Count\n\nSystem -&gt; Database : Notify All Admins\\n(\&quot;Provider requests cancellation\\nof N bookings for bus change\&quot;)\nDatabase --&gt; System : Notifications Created\n\nSystem --&gt; Provider : Display Success\\n(\&quot;Request sent to admin\&quot;)\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ma6bg-hOmN3jbMxhbQdS-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2180" width="551" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
