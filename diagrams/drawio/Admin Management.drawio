<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="i2ezEX2ueDhS-o_KokhU">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Admin Management\ntitle Sequence Diagram - Admin Management\n\nactor Admin\nparticipant System\ndatabase Database\n\n== Add Location ==\n\nAdmin -&gt; System : Navigate to Add Location\nSystem --&gt; Admin : Display Location Form\n\nAdmin -&gt; System : Submit Location Details\\n(name, district, province,\\nlatitude, longitude, status)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Save Location\nDatabase --&gt; System : Location Created\nSystem --&gt; Admin : Redirect to Location List\\n(\&quot;Location added successfully\&quot;)\n\n== Add Route ==\n\nAdmin -&gt; System : Navigate to Add Route\nSystem -&gt; Database : Fetch Active Locations\nDatabase --&gt; System : Return Locations\nSystem --&gt; Admin : Display Route Form\\n(with location dropdowns)\n\nAdmin -&gt; System : Submit Route Details\\n(origin, destination, distance,\\nestimated_duration, status)\nSystem -&gt; System : Validate Input\\n(origin != destination)\nSystem -&gt; Database : Save Route\nDatabase --&gt; System : Route Created\nSystem --&gt; Admin : Redirect to Route List\\n(\&quot;Route added successfully\&quot;)\n\n== Cancel Booking ==\n\nAdmin -&gt; System : Navigate to Bookings\nSystem -&gt; Database : Fetch All Bookings\\n(with filters)\nDatabase --&gt; System : Return Booking List\nSystem --&gt; Admin : Display Booking List\n\nAdmin -&gt; System : View Booking Details\nSystem -&gt; Database : Fetch Booking with\\nUser, Schedule, Seats, Payment\nDatabase --&gt; System : Return Booking Details\nSystem --&gt; Admin : Display Booking Details\n\nAdmin -&gt; System : Click Cancel Booking\nSystem -&gt; Database : Update booking_status\\n= cancelled\nSystem -&gt; Database : Restore Available Seats\\n(available_seats += total_passengers)\nDatabase --&gt; System : Updated\n\nSystem -&gt; Database : Notify Customer\\n(\&quot;Booking #BK... cancelled by admin\&quot;)\nSystem -&gt; Database : Notify Provider\\n(\&quot;Booking #BK... cancelled by admin\&quot;)\nDatabase --&gt; System : Notifications Created\n\nSystem --&gt; Admin : Display Success Message\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="MjEcYtVm9KMJtECyoEKV-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
