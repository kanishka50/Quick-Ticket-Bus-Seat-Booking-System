<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="tELoyFkRImTNhlfPKLsx">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Notifications\ntitle Sequence Diagram - Notifications Flow\n\nactor Customer\nactor Provider as \&quot;Provider\&quot;\nactor Admin\nactor Driver\nparticipant System\ndatabase Database\n\n== Notification Triggers ==\n\nnote over System, Database\n  Notifications are created by NotificationService::send()\n  at various system events throughout the application\nend note\n\nSystem -&gt; Database : On Booking Created\\n→ Notify Customer\nSystem -&gt; Database : On Payment Success\\n→ Notify Customer + Provider\nSystem -&gt; Database : On Booking Cancelled\\n→ Notify Customer + Provider\nSystem -&gt; Database : On Driver Assigned\\n→ Notify Driver\nSystem -&gt; Database : On Driver Unassigned\\n→ Notify Driver\nSystem -&gt; Database : On Provider Registered\\n→ Notify Admin\nSystem -&gt; Database : On Cancellation Request\\n→ Notify Admin\nSystem -&gt; Database : On Provider Approved\\n→ Notify Provider\n\n== View Notifications ==\n\nCustomer -&gt; System : Navigate to Notifications\nSystem -&gt; Database : Fetch Notifications\\n(user_id, ordered by date)\nDatabase --&gt; System : Return Notifications\nSystem --&gt; Customer : Display Notification List\\n(title, message, time, read status)\n\n== Mark Single as Read ==\n\nCustomer -&gt; System : Click \&quot;Mark as Read\&quot;\\non a Notification\nSystem -&gt; Database : Update is_read = true\\n(where id and user_id match)\nDatabase --&gt; System : Updated\nSystem --&gt; Customer : Update UI\\n(remove unread styling)\n\n== Mark All as Read ==\n\nCustomer -&gt; System : Click \&quot;Mark All as Read\&quot;\nSystem -&gt; Database : Update All Unread\\nis_read = true for User\nDatabase --&gt; System : Updated\nSystem --&gt; Customer : Update UI\\n(all notifications marked read)\n\n== Dashboard Preview ==\n\nCustomer -&gt; System : View Dashboard\nSystem -&gt; Database : Fetch Top 5\\nUnread Notifications\nDatabase --&gt; System : Return Notifications\nSystem --&gt; Customer : Display Notifications\\nWidget on Dashboard\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="j8uX2L4O_udviageiHdz-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1379" width="595" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
