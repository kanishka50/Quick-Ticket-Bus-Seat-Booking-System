<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="U94sQIy9vfON0MNL_qX8">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Real-Time Bus Tracking\ntitle Sequence Diagram - Real-Time Bus Tracking\n\nactor Driver\nactor Customer\nparticipant System\nparticipant Reverb as \&quot;WebSocket\\n(Reverb)\&quot;\ndatabase Database\n\n== Driver Starts Trip ==\n\nDriver -&gt; System : Click \&quot;Start Trip\&quot;\nSystem -&gt; Database : Update DriverAssignment\\n(status = active)\nDatabase --&gt; System : Updated\nSystem --&gt; Driver : Redirect to Trip Page\\n(\&quot;Location sharing active\&quot;)\n\n== Driver Broadcasts Location (every 15s) ==\n\nDriver -&gt; Driver : Browser Geolocation API\\ncollects GPS coordinates\n\nloop Every 15 Seconds\n  Driver -&gt; System : POST /driver/location\\n(latitude, longitude, speed,\\nlocation_name, assignment_id)\n  System -&gt; System : Validate Driver\\nand Active Assignment\n  System -&gt; Database : Upsert BusLocation\\n(updateOrCreate by driver_id)\n  Database --&gt; System : Location Saved\n\n  System -&gt; Reverb : Broadcast BusLocationUpdated\\n(channel: tracking.{scheduleDateId})\n  Reverb -&gt; Customer : Push location.updated Event\\n(lat, lng, speed, location_name)\n\n  Customer -&gt; Customer : Update Map Marker\\nand Info Panel\nend\n\n== Customer Views Live Tracking ==\n\nCustomer -&gt; System : Navigate to Tracking Page\\nfor Booking\nSystem -&gt; Database : Fetch Latest BusLocation\nDatabase --&gt; System : Return Location Data\nSystem --&gt; Customer : Display Map with\\nBus Marker (Leaflet.js)\n\nCustomer -&gt; Reverb : Subscribe to\\nchannel tracking.{scheduleDateId}\nReverb --&gt; Customer : Connection Established\n\nnote right of Customer\n  Receives real-time updates\n  via WebSocket from here\nend note\n\n== Driver Ends Trip ==\n\nDriver -&gt; System : Click \&quot;End Trip\&quot;\nSystem -&gt; Database : Update DriverAssignment\\n(status = completed)\nSystem -&gt; Database : Delete BusLocation Record\nDatabase --&gt; System : Updated\nSystem --&gt; Driver : Redirect to Dashboard\\n(\&quot;Trip completed\&quot;)\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Z2ygikA7w8D_nHh0JSeO-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1350" width="796" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
