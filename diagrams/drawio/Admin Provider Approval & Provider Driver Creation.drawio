<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="n2iSYukq7mkj6Hl6R27B">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Admin Provider Approval &amp; Driver Creation\ntitle Sequence Diagram - Admin Provider Approval &amp; Provider Driver Creation\n\nactor Admin\nactor Provider as \&quot;Provider\&quot;\nparticipant System\ndatabase Database\n\n== Admin Approves Provider ==\n\nAdmin -&gt; System : Navigate to Provider Management\nSystem -&gt; Database : Fetch Providers\\n(filter by status)\nDatabase --&gt; System : Return Provider List\nSystem --&gt; Admin : Display Provider List\\n(Company, Contact, Status)\n\nAdmin -&gt; System : Click \&quot;Update Status\&quot;\\nfor a Provider\nSystem --&gt; Admin : Display Status Update Modal\\n(status dropdown, reason field)\n\nAdmin -&gt; System : Select Status = \&quot;Active\&quot;\\nand Submit\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Update Provider Status\\n(status = active)\nDatabase --&gt; System : Status Updated\n\nSystem -&gt; Database : Create Notification\\nfor Provider User\\n(\&quot;Account Approved\&quot;)\nDatabase --&gt; System : Notification Created\n\nSystem --&gt; Admin : Display Success Message\\n(\&quot;Provider status updated\&quot;)\n\n== Admin Rejects/Suspends Provider ==\n\nAdmin -&gt; System : Click \&quot;Update Status\&quot;\\nfor a Provider\nSystem --&gt; Admin : Display Status Update Modal\n\nAdmin -&gt; System : Select Status = \&quot;Suspended\&quot;\\nEnter Reason and Submit\nSystem -&gt; System : Validate Input\\n(reason required)\nSystem -&gt; Database : Update Provider\\n(status=suspended, reason)\nDatabase --&gt; System : Status Updated\n\nSystem -&gt; Database : Create Notification\\nfor Provider User\\n(\&quot;Account Suspended\&quot;)\nDatabase --&gt; System : Notification Created\n\nSystem --&gt; Admin : Display Success Message\n\n== Provider Creates Driver Account ==\n\nProvider -&gt; System : Navigate to Driver Management\nSystem -&gt; Database : Fetch Provider&#39;s Drivers\nDatabase --&gt; System : Return Driver List\nSystem --&gt; Provider : Display Driver List\n\nProvider -&gt; System : Click \&quot;Add Driver\&quot;\nSystem --&gt; Provider : Display Driver Creation Form\n\nProvider -&gt; System : Submit Driver Details\\n(name, email, phone,\\nlicense_number, password)\nSystem -&gt; System : Validate Input\nSystem -&gt; Database : Check Email Uniqueness\nDatabase --&gt; System : Email Available\n\nSystem -&gt; Database : Create User Record\\n(user_type=driver,\\nemail_verified_at=now())\nDatabase --&gt; System : User Created\n\nSystem -&gt; Database : Create Driver Record\\n(provider_id, license_number,\\nphone, status=active)\nDatabase --&gt; System : Driver Created\n\nSystem --&gt; Provider : Redirect to Driver List\\n(\&quot;Driver added successfully\&quot;)\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tyW622NQdQDUKJG0k0kc-1">
