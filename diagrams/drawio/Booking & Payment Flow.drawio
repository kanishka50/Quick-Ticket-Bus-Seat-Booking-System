<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36 Edg/145.0.0.0" version="29.6.0">
  <diagram name="Page-1" id="k_0zW0QTDyBr7KLqVKfb">
    <mxGraphModel dx="895" dy="505" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Booking &amp; Payment\ntitle Sequence Diagram - Booking &amp; Payment Flow\n\nactor Customer\nparticipant System\nparticipant PayHere\ndatabase Database\n\n== Search Buses ==\n\nCustomer -&gt; System : Select Origin, Destination, Date\nSystem -&gt; Database : Find Route\\n(origin + destination)\nSystem -&gt; Database : Fetch Schedules\\nfor Route and Date\nDatabase --&gt; System : Return Available Schedules\nSystem --&gt; Customer : Display Schedule List\\n(bus, times, price, seats)\n\n== Select Seats ==\n\nCustomer -&gt; System : Click \&quot;Book Now\&quot; on Schedule\nSystem -&gt; Database : Fetch Seat Layout\\nand Booked Seats\nDatabase --&gt; System : Return Seat Data\nSystem --&gt; Customer : Display Seat Layout\n\nCustomer -&gt; System : Select Seats\\nand Click \&quot;Continue to Payment\&quot;\nSystem -&gt; System : Validate Departure\\nNot Passed\nSystem -&gt; Database : Check Seats Still Available\nDatabase --&gt; System : Seats Available\n\nSystem -&gt; Database : Create Booking\\n(status=pending, payment=pending)\nSystem -&gt; Database : Create SeatBooking Records\\n(ticket numbers generated)\nSystem -&gt; Database : Decrement available_seats\nDatabase --&gt; System : Booking Created\n\nSystem -&gt; Database : Notify Customer\\n(\&quot;Booking created, complete payment\&quot;)\nSystem --&gt; Customer : Redirect to Payment Page\n\n== PayHere Payment ==\n\nCustomer -&gt; System : Click \&quot;Pay Now\&quot;\nSystem --&gt; Customer : Open PayHere Gateway\nCustomer -&gt; PayHere : Enter Payment Details\nPayHere -&gt; PayHere : Process Payment\n\nPayHere -&gt; System : POST /payment/notify\\n(callback with status)\nSystem -&gt; System : Verify Hash Signature\nSystem -&gt; Database : Create Payment Record\\n(status=completed)\nSystem -&gt; Database : Update Booking\\n(payment=paid, status=confirmed)\nSystem -&gt; Database : Notify Customer\\n(\&quot;Booking confirmed\&quot;)\nSystem -&gt; Database : Notify Provider\\n(\&quot;New booking received\&quot;)\nDatabase --&gt; System : Updated\n\nPayHere --&gt; Customer : Payment Complete\nCustomer -&gt; System : Redirected to Success Page\nSystem --&gt; Customer : Display Booking Confirmation\\n(booking details, ticket info)\n\n== Download Receipt ==\n\nCustomer -&gt; System : Click \&quot;Download Receipt\&quot;\nSystem -&gt; System : Generate PDF Receipt\nSystem --&gt; Customer : Download PDF File\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f8gUdh6QLHiSwiaWY7Kw-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1648" width="589" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
